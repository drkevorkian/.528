# Cursor / tooling: keep file tree and codebase indexing within limits.
# Mirrors heavy paths from .gitignore — without this, target/ still gets scanned.

# Rust build outputs (often 10k+ files; largest source of "tree truncated")
target/
**/target/

# Local runtime, benches, logs (under repo root)
var/

# Fuzz / coverage
coverage/
tests/fuzz/artifacts/
*.profraw

# Optional large vendor trees if introduced later
node_modules/
